# ── REDDIT PRAW (Social sentiment) ────────────────────────────────────────────
# Free at: https://www.reddit.com/prefs/apps → Create App → Script
# 1. Click "create app" at bottom
# 2. Choose "script"
# 3. Name it "ATLAS"
# 4. Redirect URI: http://localhost:8080
# 5. Copy client_id (under app name) and secret
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ATLAS/1.0

# ── DISCORD WEBHOOK (Optional: alerts) ────────────────────────────────────────
# Free: In any Discord server → Channel Settings → Integrations → Webhooks
# Get a notification every time ATLAS fires a trade
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
